# NovaMart Playwright Test Configuration
# Copy this to .env and adjust values as needed

# Target URL - override this in CI/CD or AIT
BASE_URL=http://localhost:3000

# Test Environment
TEST_ENV=development

# Timeouts (milliseconds)
TEST_TIMEOUT=30000
EXPECT_TIMEOUT=5000
NAVIGATION_TIMEOUT=15000

# Test Data
TEST_USER_EMAIL=demo@novamart.com
TEST_USER_PASSWORD=demo123

# Browser Configuration
HEADLESS=true
SLOW_MO=0

# Retry Configuration
TEST_RETRIES=1
MAX_WORKERS=4

# Visual Regression
ENABLE_VISUAL_REGRESSION=false
VISUAL_THRESHOLD=0.2

# Performance Thresholds
MAX_PAGE_LOAD_TIME=3000
MAX_LCP=2500
MAX_PAGE_SIZE_KB=3000
